# Copy to .env.local and fill your local secrets.

# Optional: Feishu bot webhook push
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxxxxxx

# Feishu Base sync
FEISHU_BASE_ENABLED=true
FEISHU_BASE_APP_ID=cli_xxxxxxxxxxxxxxxxx
FEISHU_BASE_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_BASE_APP_TOKEN=bascn_xxxxxxxxxxxxxxxxx
FEISHU_BASE_MAIN_TABLE_NAME=AI行业动态表

# Optional: pin to an existing table
# FEISHU_BASE_MAIN_TABLE_ID=tblxxxxxxxxxxxxxxxxx
# FEISHU_BASE_AUTO_INIT_TABLE=true
